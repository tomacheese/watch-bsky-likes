    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "generate-schema": "typescript-json-schema --required src/config.ts IConfiguration -o schema/Configuration.json"
  }
